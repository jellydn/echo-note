{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "echo-note",
	"version": "0.1.0",
	"identifier": "com.huynhdung.echo-note",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "echo-note",
				"width": 800,
				"height": 600
			}
		],
		"security": {
			"csp": {
				"default-src": "'self'",
				"script-src": "'self'",
				"style-src": "'self' 'unsafe-inline'",
				"img-src": "'self' data:",
				"connect-src": "'self' http://localhost:* https://api.openai.com https://*.openai.com"
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": {
			"resources/BlackHole2ch-0.6.0.pkg": "resources/BlackHole2ch-0.6.0.pkg"
		}
	}
}
